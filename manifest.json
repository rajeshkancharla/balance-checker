{
  "manifest_version": 3,
  "name": "Local Card Balance Helper",
  "version": "0.1.0",
  "description": "Encrypted local helper for checking prepaid card balances on cardbalance.com.au.",
  "permissions": ["storage", "tabs"],
  "host_permissions": ["https://www.cardbalance.com.au/*"],
  "action": {
    "default_title": "Card Balance",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.cardbalance.com.au/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
